{
  "name": "omakeikka-wp-theme",
  "private": true,
  "browserslist": [
    "extends @roots/browserslist-config"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "type": "module",
  "scripts": {
    "watch": "bud dev",
    "dev": "bud build development",
    "build": "bud build",
    "pre-build": "esbuild --bundle --platform=node --format=esm --tsconfig=tsconfig.json --outdir=./public/js ./resources/scripts/build.ts && node ./public/js/build.js ./resources/data",
    "lint": "eslint resources/scripts --ext .js,.ts,.vue",
    "translate": "npm run translate:pot && yarn translate:update",
    "translate:pot": "wp i18n make-pot . ./resources/lang/sage.pot --include=\"app,resources\"",
    "translate:update": "wp i18n update-po ./resources/lang/sage.pot ./resources/lang/*.po",
    "translate:compile": "npm run translate:mo && yarn translate:js",
    "translate:js": "wp i18n make-json ./resources/lang --pretty-print",
    "translate:mo": "wp i18n make-mo ./resources/lang ./resources/lang"
  },
  "devDependencies": {
    "@mapbox/geojson-extent": "^1.0.1",
    "@roots/bud": "^6.14.3",
    "@roots/bud-framework": "^6.14.3",
    "@roots/bud-sass": "^6.14.3",
    "@roots/bud-typescript": "^6.14.3",
    "@roots/bud-vue": "^6.14.3",
    "@roots/sage": "6.14.3",
    "@types/bootstrap": "^5.2.6",
    "@types/geojson": "^7946.0.10",
    "@types/mapbox__geojson-extent": "^1.0.0",
    "@types/mapbox__sphericalmercator": "^1.2.0",
    "@types/three": "^0.154.0",
    "@types/underscore": "^1.11.6",
    "@typescript-eslint/eslint-plugin": "^5.40.0",
    "@typescript-eslint/parser": "^5.40.0",
    "@vue/compiler-sfc": "^3.3.4",
    "@vue/eslint-config-typescript": "^11.0.3",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-vue": "^9.5.1",
    "typescript": "^4.6.4",
    "vue": "^3.3.4",
    "vue-loader": "^16.1.2",
    "vue-tsc": "^0.40.4"
  },
  "dependencies": {
    "@mapbox/sphericalmercator": "^1.2.0",
    "@popperjs/core": "^2.11.8",
    "@svgdotjs/svg.js": "^3.2.0",
    "axios": "^1.4.0",
    "bootstrap": "^5.3.0",
    "geolib": "^3.3.4",
    "honeycomb-grid": "^4.1.3",
    "leader-line-new": "^1.1.9",
    "popmotion": "^11.0.5",
    "underscore": "^1.13.6"
  }
}
